{
  "project": "ELM369 JMR0824197846902",
  "auto_update_configuration": {
    "enabled": true,
    "frequency": "daily",
    "schedule_time": "06:00 AM",
    "timezone": "America/Indiana/Knox",
    "location": {
      "city": "Kokomo",
      "state": "Indiana",
      "country": "USA",
      "postal_code": "46902",
      "latitude": 40.4831,
      "longitude": -86.1637
    }
  },
  "cron_expression": "0 6 * * *",
  "cron_description": "Every day at 6:00 AM America/Indiana/Knox timezone",
  "update_tasks": [
    {
      "id": "task_001",
      "name": "Security Policy Verification",
      "schedule": "0 6 * * *",
      "action": "verify_security_localization_policy.sh",
      "timeout_seconds": 300,
      "retry_on_failure": true,
      "max_retries": 3
    },
    {
      "id": "task_002",
      "name": "Language Configuration Check",
      "schedule": "0 6 * * *",
      "action": "validate_language_config.py",
      "timeout_seconds": 120,
      "retry_on_failure": true,
      "max_retries": 2
    },
    {
      "id": "task_003",
      "name": "Access Log Rotation",
      "schedule": "0 6 * * *",
      "action": "rotate_access_logs.sh",
      "timeout_seconds": 180,
      "retry_on_failure": true,
      "max_retries": 2
    },
    {
      "id": "task_004",
      "name": "Database Optimization",
      "schedule": "0 6 * * *",
      "action": "optimize_database.sql",
      "timeout_seconds": 600,
      "retry_on_failure": true,
      "max_retries": 1
    },
    {
      "id": "task_005",
      "name": "Backup Creation",
      "schedule": "0 6 * * *",
      "action": "create_daily_backup.sh",
      "timeout_seconds": 900,
      "retry_on_failure": true,
      "max_retries": 2
    },
    {
      "id": "task_006",
      "name": "Compliance Audit",
      "schedule": "0 6 * * *",
      "action": "run_compliance_audit.py",
      "timeout_seconds": 240,
      "retry_on_failure": true,
      "max_retries": 1
    },
    {
      "id": "task_007",
      "name": "System Update Check",
      "schedule": "0 6 * * *",
      "action": "check_system_updates.sh",
      "timeout_seconds": 180,
      "retry_on_failure": true,
      "max_retries": 2
    },
    {
      "id": "task_008",
      "name": "Configuration Sync",
      "schedule": "0 6 * * *",
      "action": "sync_all_configs.py",
      "timeout_seconds": 300,
      "retry_on_failure": true,
      "max_retries": 1
    }
  ],
  "notification_settings": {
    "enable_notifications": true,
    "notify_on_success": true,
    "notify_on_failure": true,
    "notification_channels": [
      "email",
      "slack",
      "system_log"
    ],
    "email_recipients": [
      "elkabalatesla@gmail.com"
    ]
  },
  "logging": {
    "log_level": "INFO",
    "log_file": "/var/log/elm369/auto_update_schedule.log",
    "log_retention_days": 90,
    "timestamp_format": "2006-01-02 15:04:05 MST",
    "include_location_metadata": true
  },
  "rollback_settings": {
    "enable_rollback": true,
    "rollback_on_failure": true,
    "keep_backup_copies": 7,
    "backup_directory": "/backups/elm369"
  }
}
