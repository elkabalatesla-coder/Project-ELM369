{\n  "$schema": "http://json-schema.org/draft-07/schema#",\n  "title": "CreatorIdentificationCard",\n  "type": "object",\n  "properties": {\n    "id": {\n      "type": "string",\n      "description": "Unique identifier for the creator."\n    },\n    "name": {\n      "type": "string",\n      "description": "Name of the creator."\n    },\n    "email": {\n      "type": "string",\n      "format": "email",\n      "description": "Email address of the creator."\n    },\n    "profilePicture": {\n      "type": "string",\n      "format": "uri",\n      "description": "URL of the creator's profile picture."\n    },\n    "socialLinks": {\n      "type": "array",\n      "items": {\n        "type": "string",\n        "format": "uri"\n      },\n      "description": "Array of social media links."\n    },\n    "bio": {\n      "type": "string",\n      "description": "Short biography of the creator."\n    },\n    "createdDate": {\n      "type": "string",\n      "format": "date-time",\n      "description": "Timestamp when the creator was registered."\n    }\n  },\n  "required": ["id", "name", "email", "createdDate"]\n}